# First Light AI local automation
# Copy to .env locally. Never commit real values.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-read-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-write-key

# Discord token still belongs only on the local machine.
# The cron wrapper also supports discord_export_config.env for this value.
DISCORD_TOKEN=your-local-discord-token
