# ───────── Supabase ─────────
# Required for db/supabase_ingest.py, scripts/backfill_sqlite_to_supabase.py,
# and any publisher path that uses USE_DB=true.
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role: write path (crawlers, ingest, pipeline_state). Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# publishable/anon: read-only, safe for static-site consumers of the articles table.
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# ───────── Publisher state mode ─────────
# true → publisher uses Supabase publish_log. false → uses data/published.json (legacy).
USE_DB=false

# ───────── Telegram (optional, for future publisher GH Actions) ─────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHANNEL_ID=@your_channel_id

# ───────── X (Twitter) — OAuth 2.0 (optional) ─────────
X_CLIENT_ID=your_client_id
X_CLIENT_SECRET=your_client_secret
X_REFRESH_TOKEN=your_refresh_token

# ───────── LLM (article generation) ─────────
GOOGLE_API_KEY=your_key
# GOOGLE_API_KEYS=key1,key2,key3   # comma-separated rotation

# ───────── Discord (local crawl only — never put in GH Secrets) ─────────
DISCORD_TOKEN=local_only_do_not_commit
